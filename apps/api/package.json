{
  "name": "@zakayola/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "jest --forceExit"
  },
  "dependencies": {
    "@zakayola/types": "*",
    "@stellar/stellar-sdk": "^12.0.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.12.0",
    "@types/supertest": "^6.0.2",
    "@types/jest": "^29.5.12",
    "typescript": "^5.4.0",
    "ts-node-dev": "^2.0.0",
    "ts-jest": "^29.1.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "globals": {
      "ts-jest": { "tsconfig": "tsconfig.json" }
    }
  }
}
